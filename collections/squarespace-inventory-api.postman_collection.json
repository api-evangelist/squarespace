          "name": "Retrieve Specific Inventory",
          "request": {
            "name": "Retrieve Specific Inventory",
            "description": {
              "content": "Retrieves real-time stock information for up to 50 specific product variants by their variant IDs. Variant IDs should be provided as a comma-separated list in the path. This endpoint is useful for checking stock levels on specific items without paginating through the full inventory.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "commerce",
                "inventory",
                ":variantIds"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "variantIds",
                  "description": "(Required) Comma-separated list of up to 50 product variant IDs for which to retrieve inventory information"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
