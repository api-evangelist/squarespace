    "_postman_id": "601baa84-c2e3-4324-820c-7b6e380c32e2",
    "name": "Squarespace Profiles API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Squarespace Profiles API provides access to Profile resource objects representing customers, mailing list subscribers, and donors associated with a Squarespace site. Each profile includes contact information, an approximate address derived from existing data, and a summary of the user's commerce activity such as orders and donations. This API is useful for CRM integrations, email marketing platforms, and customer analytics tools. Profile data is generated asynchronously from site activity and accessible through the standard Profiles panel.\n\nContact Support:\n Name: Squarespace Developer Support",
      "type": "text/plain"
    }
  }
