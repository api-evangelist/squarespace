        {
          "id": "843424bd-2714-4559-b897-24551ccb7d8d",
          "name": "Retrieve All Profiles",
          "request": {
            "name": "Retrieve All Profiles",
            "description": {
              "content": "Returns a paginated list of profiles associated with the merchant site. Profiles represent customers, mailing list subscribers, and donors. By default returns up to 50 profiles per page. Results can be filtered by profile type, account status, or email address. Use the cursor parameter from the previous response's pagination.nextPageCursor to iterate through all profiles.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "profiles"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "cursor",
                  "value": "<string>",
                  "description": "Pagination cursor from a previous response's pagination.nextPageCursor field. Omit or leave empty to retrieve the first page."
                },
                {
                  "disabled": false,
                  "key": "isCustomer",
                  "value": "<boolean>",
                  "description": "When true, filters results to only include customer profiles"
                },
                {
                  "disabled": false,
                  "key": "hasAccount",
                  "value": "<boolean>",
                  "description": "When true, filters to profiles associated with a Squarespace account. When false, filters to anonymous profiles."
                },
                {
                  "disabled": false,
                  "key": "email",
                  "value": "<email>",
                  "description": "Filter profiles by exact email address match"
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
